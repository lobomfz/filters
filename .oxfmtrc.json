{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortImports": {
    "newlinesBetween": false
  },
  "ignorePatterns": ["dist", "node_modules", "routeTree.gen.ts"]
}
