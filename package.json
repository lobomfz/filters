{
  "name": "@lobomfz/filters",
  "version": "0.1.0",
  "private": false,
  "description": "Headless, Kysely-native filter builder with Arktype schema introspection",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo",
    "check": "bun run scripts/check.ts",
    "ci": "bun run build && bun run format && bun run check-exports",
    "test": "bun test",
    "format": "oxfmt check --write src tests",
    "check-exports": "attw --pack . --ignore-rules cjs-resolves-to-esm no-resolution",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "bun run ci"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@lobomfz/db": "0.3.8",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "^7.0.0-dev.20260324.1",
    "arktype": "^2.2.0",
    "happy-dom": "^20.8.9",
    "jscpd": "^4.0.8",
    "kysely": "^0.28.14",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react": "19.2.5",
    "react-dom": "^19.2.5"
  },
  "peerDependencies": {
    "arktype": "^2.1.29",
    "kysely": "^0.28.14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
